# SibyX 中继 · 环境变量示例
# 复制为 .env 并在本地使用；在 Render 上直接填到服务 Environment（不要提交真实值）

# ---- 匿名访问统计（B 档，可选；不填则统计停用，不影响主服务）----
# Upstash Redis（免费层 10k 命令/天，beta 够用）
# 控制台：https://upstash.com → 新建 Redis 数据库 → 复制 REST URL / Token
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IP 哈希加盐密钥（请用强随机串，例如：openssl rand -hex 32）
IP_SALT=change-me-to-a-long-random-string

# 看板访问令牌（强随机，例如：openssl rand -hex 24）
# 访问 https://<你的中继>/admin?token=此处值   或  Header: Authorization: Bearer 此处值
ADMIN_TOKEN=change-me-to-a-long-random-token

# ---- 中继自身（已有）----
PORT=8765
GUN_FILE=./data
